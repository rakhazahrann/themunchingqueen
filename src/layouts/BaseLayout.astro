---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { site } from '../data/site';
import { ClientRouter } from 'astro:transitions';

const { title, description, image = '/images/lifestyle/fish-cheese.webp' } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.domain);
const fullTitle = title ? `${title} · ${site.name}` : site.name;
const organization = {
  '@context': 'https://schema.org', '@type': 'Organization', name: site.name, url: site.domain,
  email: site.email, telephone: site.phone, sameAs: [site.instagramUrl],
};
---
<!doctype html>
<html lang="en" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/images/logo/the-munching-queen.webp" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, site.domain)} />
    <meta name="theme-color" content="#FFFAF2" />
    <script is:inline>
      (function() {
        document.documentElement.classList.replace('no-js', 'js');
        var saved = localStorage.getItem('tmq-language') || 'en';
        document.documentElement.lang = saved;
        document.documentElement.setAttribute('data-lang', saved);

        function applyEarlyLang() {
          var lang = localStorage.getItem('tmq-language') || 'en';
          document.querySelectorAll('[data-en][data-id]').forEach(function(el) {
            if (el.dataset[lang]) {
              el.textContent = el.dataset[lang];
            }
          });
          document.querySelectorAll('[data-lang]').forEach(function(btn) {
            btn.setAttribute('aria-pressed', String(btn.dataset.lang === lang));
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', applyEarlyLang);
        } else {
          applyEarlyLang();
        }
      })();
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(organization)} />
    <ClientRouter />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main" data-en="Skip to content" data-id="Lewati ke konten">Skip to content</a>
    <Header />
    <main id="main"><slot /></main>
    <Footer />
    <script>
      import { initAnimations } from '../scripts/animations';

      const applyLanguage = (lang: 'en' | 'id') => {
        document.documentElement.lang = lang;
        document.documentElement.setAttribute('data-lang', lang);
        document.querySelectorAll<HTMLElement>('[data-en][data-id]').forEach((element) => {
          element.textContent = element.dataset[lang] ?? element.textContent;
        });
        document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((button) => {
          button.setAttribute('aria-pressed', String(button.dataset.lang === lang));
        });
        localStorage.setItem('tmq-language', lang);
        window.dispatchEvent(new CustomEvent('tmq:lang-changed', { detail: { lang } }));
      };

      const setupAppScript = () => {
        const saved = localStorage.getItem('tmq-language');
        applyLanguage(saved === 'id' ? 'id' : 'en');

        document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((button) => {
          button.onclick = () => applyLanguage(button.dataset.lang === 'id' ? 'id' : 'en');
        });

        const menu = document.querySelector<HTMLElement>('#site-nav');
        const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
        const overlay = document.querySelector<HTMLElement>('[data-nav-overlay]');

        const setMenuState = (open: boolean) => {
          if (!menu || !toggle) return;
          menu.classList.toggle('is-open', open);
          overlay?.classList.toggle('is-open', open);
          toggle.setAttribute('aria-expanded', String(open));
          toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
          document.body.classList.toggle('nav-open', open);
        };

        if (toggle) {
          toggle.onclick = () => {
            const isOpen = menu?.classList.contains('is-open') ?? false;
            setMenuState(!isOpen);
          };
        }

        if (overlay) {
          overlay.onclick = () => setMenuState(false);
        }

        menu?.querySelectorAll('a').forEach((link) => {
          link.onclick = () => setMenuState(false);
        });

        window.onkeydown = (e) => {
          if (e.key === 'Escape' && menu?.classList.contains('is-open')) {
            setMenuState(false);
          }
        };

        const header = document.querySelector('[data-header]');
        const setHeader = () => header?.classList.toggle('is-scrolled', window.scrollY > 12);
        setHeader();
        window.onscroll = setHeader;

        initAnimations();
      };

      setupAppScript();
      document.addEventListener('astro:page-load', setupAppScript);
    </script>
  </body>
</html>
