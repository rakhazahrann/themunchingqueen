---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import MarketplaceLinks from '../components/MarketplaceLinks.astro';
import CertIcon from '../components/CertIcon.astro';
import { certifications } from '../data/site';
import { categories, featured } from '../data/products';
const featuredTones = [categories[0].color, categories[2].color, categories[3].color];
const featuredClaims = [categories[0].claims, categories[2].claims, categories[3].claims];
---
<BaseLayout title="Healthy snacks, happy little munchers" description="The Munching Queen creates thoughtfully made Indonesian snacks for families, using real ingredients and joyful flavours.">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow" data-en="From Surabaya, with a happy crunch" data-id="Dari Surabaya, dengan kerenyahan ceria">From Surabaya, with a happy crunch</span>
        <h1><span data-en="Made for little hands." data-id="Dibuat untuk tangan mungil.">Made for little hands.</span> <em data-en="Loved by everyone." data-id="Disukai semua orang.">Loved by everyone.</em></h1>
        <p class="lede" data-en="Real ingredients, familiar Indonesian roots and playful flavours—made by parents who believe better snacks should still taste delicious." data-id="Bahan asli, akar kuliner Indonesia, dan rasa yang ceria—dibuat oleh para orang tua yang percaya camilan lebih baik harus tetap lezat.">Real ingredients, familiar Indonesian roots and playful flavours—made by parents who believe better snacks should still taste delicious.</p>
        <div class="button-row">
          <a class="button" href="/products"><span data-en="Meet our snacks" data-id="Kenali camilan kami">Meet our snacks</span></a>
          <a class="button button--secondary" href="#our-story"><span data-en="Read our story" data-id="Baca cerita kami">Read our story</span></a>
        </div>
      </div>
      <div class="picnic-board" aria-label="A playful arrangement of The Munching Queen snack packages">
        <div class="hero-splash" aria-hidden="true">
          <svg viewBox="0 0 620 560" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="splash-cream" x1="110" y1="55" x2="520" y2="510" gradientUnits="userSpaceOnUse">
                <stop stop-color="#FFF8E8" />
                <stop offset="0.42" stop-color="#FFE5C6" />
                <stop offset="1" stop-color="#F6BE91" />
              </linearGradient>
            </defs>
            <path class="splash-depth" transform="translate(0 12)" d="M97 102C143 59 201 77 251 57C295 40 324 61 353 48C382 35 373 2 397 3C421 4 410 42 427 61C449 85 491 69 522 91C548 109 537 136 555 146C575 158 602 132 612 151C622 171 585 183 565 201C543 221 559 250 547 277C535 304 510 313 519 342C527 370 566 385 554 411C542 438 506 422 483 438C459 454 470 492 444 503C418 514 397 481 370 485C339 490 324 535 293 527C263 520 276 479 247 467C220 455 197 490 171 475C145 460 164 426 142 408C119 389 76 415 62 388C47 360 88 341 87 312C87 286 51 276 55 250C59 224 94 226 105 205C117 182 84 171 76 146C70 127 80 116 97 102Z" />
            <path class="splash-face" d="M97 102C143 59 201 77 251 57C295 40 324 61 353 48C382 35 373 2 397 3C421 4 410 42 427 61C449 85 491 69 522 91C548 109 537 136 555 146C575 158 602 132 612 151C622 171 585 183 565 201C543 221 559 250 547 277C535 304 510 313 519 342C527 370 566 385 554 411C542 438 506 422 483 438C459 454 470 492 444 503C418 514 397 481 370 485C339 490 324 535 293 527C263 520 276 479 247 467C220 455 197 490 171 475C145 460 164 426 142 408C119 389 76 415 62 388C47 360 88 341 87 312C87 286 51 276 55 250C59 224 94 226 105 205C117 182 84 171 76 146C70 127 80 116 97 102Z" />
            <path class="splash-highlight" d="M119 119C165 80 211 96 258 77C299 61 328 78 357 65" />
            <g class="splash-drops">
              <circle cx="43" cy="174" r="9" />
              <circle cx="582" cy="244" r="7" />
              <circle cx="530" cy="484" r="10" />
              <circle cx="101" cy="458" r="6" />
            </g>
          </svg>
        </div>
        <div class="splash-details" aria-hidden="true">
          <span class="crumb crumb--one"></span>
          <span class="crumb crumb--two"></span>
          <span class="cheese cheese--one"></span>
          <span class="cheese cheese--two"></span>
          <span class="fish-cracker fish-cracker--one"></span>
          <span class="brownie-cube brownie-cube--one"></span>
          <span class="brownie-cube brownie-cube--two"></span>
          <span class="splash-sparkle sparkle--one">✦</span>
          <span class="splash-sparkle sparkle--two">✦</span>
        </div>
        <img class="hero-mascot hero-mascot--bear" src="/images/maskot/Maskot Brownies/BEAR.png" alt="Bear Mascot" loading="eager" />
        <img class="hero-mascot hero-mascot--fnc" src="/images/maskot/Maskot FNC/Artboard 1_7.png" alt="Fish and Cheese Mascot" loading="eager" />
        <img class="hero-mascot hero-mascot--crispy-1" src="/images/maskot/Maskot Brownies/CRISPY-1.png" alt="Crispy Brownies Mascot 1" loading="eager" />
        <img class="hero-pack hero-pack--one" src="/images/products/fish-cheese/original.png" alt="Fish and Cheese Original package" width="900" height="900" />
        <img class="hero-pack hero-pack--two" src="/images/products/brownies/chocolate.png" alt="Chocolate Crispy Brownies package" width="900" height="900" />
        <img class="hero-pack hero-pack--three" src="/images/products/tempeh/salmon-furikake.png" alt="Salmon Furikake Tempeh Chips package" width="900" height="900" />
        
        <div class="sticker sticker--hero">
          <svg class="sticker-shape" viewBox="0 0 160 160" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="sticker-gold" x1="35" y1="20" x2="126" y2="143" gradientUnits="userSpaceOnUse">
                <stop stop-color="#FFF2B8" />
                <stop offset="0.52" stop-color="#FFD66F" />
                <stop offset="1" stop-color="#F4B947" />
              </linearGradient>
            </defs>
            <path id="sticker-scallop" d="M80 6 C84.5 6 87.2 10.5 91.5 11.5 C95.8 12.5 100.2 9.5 104.2 11.5 C108.2 13.5 110.5 18 114.2 20.8 C117.8 23.6 122.5 24.8 125.7 28.3 C128.8 31.8 129.5 36.6 132.1 40.5 C134.7 44.4 139 46.8 141 51 C143 55.2 142 60 143.2 64.5 C144.5 69 148 72 148 76.5 C148 81 144.5 84 143.2 88.5 C142 93 143 97.8 141 102 C139 106.2 134.7 108.6 132.1 112.5 C129.5 116.4 128.8 121.2 125.7 124.7 C122.5 128.2 117.8 129.4 114.2 132.2 C110.5 135 108.2 139.5 104.2 141.5 C100.2 143.5 95.8 140.5 91.5 141.5 C87.2 142.5 84.5 147 80 147 C75.5 147 72.8 142.5 68.5 141.5 C64.2 140.5 59.8 143.5 55.8 141.5 C51.8 139.5 49.5 135 45.8 132.2 C42.2 129.4 37.5 128.2 34.3 124.7 C31.2 121.2 30.5 116.4 27.9 112.5 C25.3 108.6 21 106.2 19 102 C17 97.8 18 93 16.8 88.5 C15.5 84 12 81 12 76.5 C12 72 15.5 69 16.8 64.5 C18 60 17 55.2 19 51 C21 46.8 25.3 44.4 27.9 40.5 C30.5 36.6 31.2 31.8 34.3 28.3 C37.5 24.8 42.2 23.6 45.8 20.8 C49.5 18 51.8 13.5 55.8 11.5 C59.8 9.5 64.2 12.5 68.5 11.5 C72.8 10.5 75.5 6 80 6 Z" fill="url(#sticker-gold)" stroke="#5D3A2B" stroke-width="3.5" stroke-linejoin="round"/>
            <circle cx="80" cy="77" r="58.5" stroke="#FFFDF7" stroke-width="2.2" stroke-dasharray="2.5 3.5" stroke-linecap="round" />
          </svg>
          <div class="sticker-content">
            <span class="sticker-star" aria-hidden="true">✦</span>
            <span class="sticker-text">
              <span class="sticker-line" data-en="Happy" data-id="Selamat">Happy</span>
              <span class="sticker-line" data-en="munching!" data-id="ngemil!">munching!</span>
            </span>
            <svg class="sticker-heart" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.78-8.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="marquee" aria-hidden="true"><div class="marquee-track"><span>Real ingredients</span><span>Made by parents</span><span>Indonesian roots</span><span>Kid-friendly crunch</span><span>Real ingredients</span><span>Made by parents</span><span>Indonesian roots</span><span>Kid-friendly crunch</span></div></div>

  <section class="section" id="our-story">
    <div class="container story-grid">
      <div class="story-photo reveal"><img src="/images/lifestyle/fish-cheese.webp" alt="The Munching Queen Fish and Cheese snacks styled for sharing" width="1080" height="1350" loading="lazy" /></div>
      <div class="story-card reveal">
        <span class="eyebrow" data-en="Our story" data-id="Cerita kami">Our story</span>
        <h2 data-en="A family kitchen with a bigger dream." data-id="Dapur keluarga dengan mimpi yang lebih besar.">A family kitchen with a bigger dream.</h2>
        <p data-en="We are parents and snack enthusiasts from Surabaya. In 2016, we introduced Kroepoek Waroeng at a food expo in Dubai. Seeing international guests light up over Indonesian crackers gave us a mission: share our food heritage in a ready-to-munch, joyfully flavoured way." data-id="Kami adalah para orang tua dan pencinta camilan dari Surabaya. Pada 2016, kami memperkenalkan Kroepoek Waroeng di pameran makanan Dubai. Antusiasme pengunjung internasional terhadap kerupuk Indonesia memberi kami misi: membagikan warisan kuliner ini dalam bentuk siap santap yang penuh rasa.">We are parents and snack enthusiasts from Surabaya. In 2016, we introduced Kroepoek Waroeng at a food expo in Dubai. Seeing international guests light up over Indonesian crackers gave us a mission: share our food heritage in a ready-to-munch, joyfully flavoured way.</p>
        <p data-en="During the pandemic, we looked for locally made snacks our three-year-old would love—without the extras we did not want. We could not find enough, so we experimented with natural ingredients in our own kitchen. That is how our Fish & Cheese series, and The Munching Queen, came to life." data-id="Saat pandemi, kami mencari camilan lokal yang disukai anak kami yang berusia tiga tahun—tanpa bahan tambahan yang tidak kami inginkan. Pilihannya belum cukup, jadi kami bereksperimen dengan bahan alami di dapur sendiri. Dari situlah seri Ikan & Keju dan The Munching Queen lahir.">During the pandemic, we looked for locally made snacks our three-year-old would love—without the extras we did not want. We could not find enough, so we experimented with natural ingredients in our own kitchen. That is how our Fish & Cheese series, and The Munching Queen, came to life.</p>
        <blockquote class="pullquote" data-en="We believe quality is key—and a better snack can taste every bit as good." data-id="Kami percaya kualitas adalah kunci—dan camilan yang lebih baik tetap bisa terasa sangat lezat.">We believe quality is key—and a better snack can taste every bit as good.</blockquote>
      </div>
    </div>
  </section>

  <section class="section tone-powder">
    <div class="container">
      <span class="eyebrow" data-en="A peek inside the pantry" data-id="Mengintip isi lemari camilan">A peek inside the pantry</span>
      <h2 data-en="Something for every kind of munch." data-id="Ada camilan untuk setiap selera.">Something for every kind of munch.</h2>
      <p class="lede muted" data-en="Savoury, sweet, familiar or adventurous—start with three family favourites." data-id="Gurih, manis, familiar, atau berani—mulai dari tiga favorit keluarga.">Savoury, sweet, familiar or adventurous—start with three family favourites.</p>
      <div class="card-grid">
        {featured.map((product, index) => <ProductCard product={product} tone={featuredTones[index]} claims={featuredClaims[index]} />)}
      </div>
      <div class="button-row"><a class="button" href="/products" data-en="Explore all products" data-id="Lihat semua produk">Explore all products</a></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="center"><span class="eyebrow" data-en="Trust the process" data-id="Proses yang dapat dipercaya">Trust the process</span><h2 data-en="Made the right way, not the easy way." data-id="Dibuat dengan cara yang benar, bukan yang mudah.">Made the right way, not the easy way.</h2><p class="lede muted" data-en="Our facility, packaging and quality checks follow recognised food safety standards." data-id="Fasilitas, kemasan, dan pemeriksaan kualitas kami mengikuti standar keamanan pangan yang diakui.">Our facility, packaging and quality checks follow recognised food safety standards.</p></div>
      <div class="cert-grid">
        {certifications.map((cert) => (
          <article class="cert-card reveal">
            <div class="cert-mark">
              <CertIcon type={cert.id} />
            </div>
            <h3>{cert.title}</h3>
            <p data-en={cert.copy.en} data-id={cert.copy.id}>{cert.copy.en}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--tight"><div class="container"><div class="cta-panel reveal"><span class="eyebrow" data-en="Ready to munch?" data-id="Siap ngemil?">Ready to munch?</span><h2 data-en="Find your next favourite bag." data-id="Temukan kemasan favorit berikutnya.">Find your next favourite bag.</h2><div class="button-row" style="justify-content:center"><a class="button" href="/products" data-en="Browse flavours" data-id="Jelajahi rasa">Browse flavours</a><a class="button button--secondary" href="/contact#shop-online" data-en="Where to buy" data-id="Tempat membeli">Where to buy</a></div></div></div></section>

  <section class="section market-section" id="shop-online"><div class="container"><div class="market-heading"><div><span class="eyebrow" data-en="Shop online" data-id="Belanja online">Shop online</span><h2 data-en="Choose your nearest pantry." data-id="Pilih toko terdekat.">Choose your nearest pantry.</h2></div><p data-en="Fresh crunch, one click away. Pick an official store closest to you." data-id="Camilan renyah, tinggal satu klik. Pilih toko resmi terdekat.">Fresh crunch, one click away. Pick an official store closest to you.</p></div><MarketplaceLinks /></div></section>
</BaseLayout>
