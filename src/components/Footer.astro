---
import { nav, site } from '../data/site';
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.address)}`;
---
<footer class="site-footer">
  <div class="footer-watermark" aria-hidden="true">
    <span>THE MUNCHING QUEEN</span>
  </div>

  <div class="container footer-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/images/logo/the-munching-queen.webp" alt="The Munching Queen" width="900" height="900" loading="lazy" />
        <p data-en="Deliciously flavoured Indonesian snacks, made thoughtfully for happy little munchers." data-id="Camilan Indonesia penuh rasa, dibuat dengan penuh perhatian untuk si kecil yang bahagia.">Deliciously flavoured Indonesian snacks, made thoughtfully for happy little munchers.</p>
      </div>
      
      <div class="footer-nav-columns">
        <div class="footer-col">
          <span class="footer-col-title" data-en="Navigation" data-id="Navigasi">Navigation</span>
          <ul class="footer-contact-list">
            <li>
              <a href="/" class="footer-contact-item">
                <span class="footer-contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                  </svg>
                </span>
                <span class="footer-contact-text">
                  <span class="footer-contact-label" data-en="Story" data-id="Cerita">Story</span>
                  <span class="footer-contact-val" data-en="About us" data-id="Tentang kami">About us</span>
                </span>
              </a>
            </li>
            <li>
              <a href="/products" class="footer-contact-item">
                <span class="footer-contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <path d="M16 10a4 4 0 0 1-8 0"></path>
                  </svg>
                </span>
                <span class="footer-contact-text">
                  <span class="footer-contact-label" data-en="Snacks" data-id="Camilan">Snacks</span>
                  <span class="footer-contact-val" data-en="Products" data-id="Produk">Products</span>
                </span>
              </a>
            </li>
            <li>
              <a href="/contact" class="footer-contact-item">
                <span class="footer-contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                  </svg>
                </span>
                <span class="footer-contact-text">
                  <span class="footer-contact-label" data-en="Inquiries" data-id="Pertanyaan">Inquiries</span>
                  <span class="footer-contact-val" data-en="Contact us" data-id="Hubungi kami">Contact us</span>
                </span>
              </a>
            </li>
          </ul>
        </div>

        <div class="footer-col">
          <span class="footer-col-title" data-en="Connect" data-id="Hubungi Kami">Connect</span>
          <ul class="footer-contact-list">
            <li>
              <a href={mapsUrl} target="_blank" rel="noreferrer" class="footer-contact-item" title="Open in Google Maps">
                <span class="footer-contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </span>
                <span class="footer-contact-text">
                  <span class="footer-contact-label" data-en="Address" data-id="Alamat">Address</span>
                  <span class="footer-contact-val">{site.address}</span>
                </span>
              </a>
            </li>
            <li>
              <a href={`mailto:${site.email}`} class="footer-contact-item">
                <span class="footer-contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                </span>
                <span class="footer-contact-text">
                  <span class="footer-contact-label" data-en="Email" data-id="Email">Email</span>
                  <span class="footer-contact-val">{site.email}</span>
                </span>
              </a>
            </li>
            <li>
              <a href={`https://wa.me/${site.phoneHref.slice(1)}`} target="_blank" rel="noreferrer" class="footer-contact-item">
                <span class="footer-contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984 0 1.76.459 3.475 1.33 4.985l-1.413 5.163 5.283-1.385c1.455.793 3.095 1.211 4.787 1.212h.004c5.505 0 9.988-4.478 9.989-9.984 0-2.668-1.038-5.176-2.924-7.062a9.923 9.923 0 0 0-7.066-2.913zm5.782 14.402c-.244.688-1.42 1.312-1.96 1.393-.497.075-1.137.108-1.832-.115-1.18-.378-2.673-1.077-4.103-2.355-1.748-1.562-2.92-3.487-3.23-4.017-.309-.53-.033-.816.213-1.062.221-.22.493-.574.739-.861.246-.288.328-.492.493-.82.164-.329.082-.616-.041-.862-.123-.246-1.067-2.571-1.463-3.518-.386-.923-.778-.797-1.067-.812-.274-.015-.59-.015-.905-.015s-.824.118-1.258.59c-.434.473-1.658 1.621-1.658 3.951 0 2.33 1.699 4.58 1.932 4.894.233.314 3.344 5.106 8.1 7.16 1.131.489 2.014.781 2.702 1.001 1.135.361 2.169.31 2.986.188.911-.136 2.8-1.144 3.197-2.25.397-1.106.397-2.053.279-2.251-.118-.198-.434-.316-.906-.552z"/>
                  </svg>
                </span>
                <span class="footer-contact-text">
                  <span class="footer-contact-label" data-en="WhatsApp" data-id="WhatsApp">WhatsApp</span>
                  <span class="footer-contact-val">{site.phone}</span>
                </span>
              </a>
            </li>
            <li>
              <a href={site.instagramUrl} target="_blank" rel="noreferrer" class="footer-contact-item">
                <span class="footer-contact-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                  </svg>
                </span>
                <span class="footer-contact-text">
                  <span class="footer-contact-label" data-en="Instagram" data-id="Instagram">Instagram</span>
                  <span class="footer-contact-val">{site.instagram}</span>
                </span>
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copy">© {new Date().getFullYear()} CV. Trinusa Jaya Abadi · The Munching Queen</div>
    </div>
  </div>
</footer>
