---
import { nav } from '../data/site';
const { pathname } = Astro.url;
const active = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
---
<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label="The Munching Queen home">
      <img src="/images/logo/the-munching-queen.webp" alt="" width="900" height="900" />
    </a>
    <div class="nav-wrap">
      <nav class="site-nav" id="site-nav" aria-label="Primary navigation">
        {nav.map((item) => (
          <a class="nav-link" href={item.href} aria-current={active(item.href) ? 'page' : undefined} data-en={item.label.en} data-id={item.label.id}>{item.label.en}</a>
        ))}
      </nav>
      <div class="lang-switch" aria-label="Language">
        <button type="button" data-lang="en" aria-pressed="true">EN</button>
        <button type="button" data-lang="id" aria-pressed="false">ID</button>
      </div>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Open menu" data-menu-toggle><span></span><span></span></button>
    </div>
  </div>
</header>
