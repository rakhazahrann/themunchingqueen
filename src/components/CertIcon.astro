---
interface Props {
  type: string;
}

const { type } = Astro.props;
---

{type === 'iso' && (
  <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="ISO 22000 Certification Logo">
    <!-- outer rosette ring -->
    <circle cx="50" cy="50" r="46" fill="#F4F9F5" stroke="#2B6B4C" stroke-width="3"/>
    <circle cx="50" cy="50" r="41" stroke="#2B6B4C" stroke-width="1.5" stroke-dasharray="4 2"/>
    
    <!-- Shield / Globe grid in background -->
    <path d="M50 18 C30 18 20 28 20 48 C20 68 40 80 50 84 C60 80 80 68 80 48 C80 28 70 18 50 18 Z" fill="#2B6B4C" fill-opacity="0.08" stroke="#2B6B4C" stroke-width="2"/>
    
    <!-- ISO text banner -->
    <rect x="25" y="38" width="50" height="20" rx="4" fill="#2B6B4C"/>
    <text x="50" y="52" fill="#FFFFFF" font-family="'Nunito Sans', sans-serif" font-weight="900" font-size="13" text-anchor="middle" letter-spacing="1.5">ISO</text>
    
    <!-- 22000 subtext -->
    <text x="50" y="68" fill="#1C4833" font-family="'Nunito Sans', sans-serif" font-weight="800" font-size="10" text-anchor="middle">22000:2005</text>

    <!-- Star accent top -->
    <polygon points="50,22 51.5,26 55.5,26.3 52.5,29 53.4,33 50,30.8 46.6,33 47.5,29 44.5,26.3 48.5,26" fill="#D4A359"/>
  </svg>
)}

{type === 'haccp' && (
  <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="HACCP Certification Logo">
    <!-- Circular Seal border -->
    <circle cx="50" cy="50" r="46" fill="#F4F9F5" stroke="#236343" stroke-width="3"/>
    
    <!-- Outer scalloped edge detail -->
    <circle cx="50" cy="50" r="41" stroke="#378D61" stroke-width="1.5" stroke-dasharray="3 3"/>

    <!-- Safety Shield emblem -->
    <path d="M50 17 L74 27 V48 C74 65 60 77 50 82 C40 77 26 65 26 48 V27 L50 17 Z" fill="#236343"/>
    <path d="M50 20 L71 29 V47 C71 62 59 73 50 78 C41 73 29 62 29 47 V29 L50 20 Z" fill="#2D7B54"/>

    <!-- Checkmark inside shield -->
    <path d="M41 49 L47 55 L59 41" stroke="#FFFFFF" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>

    <!-- Text HACCP banner below shield -->
    <rect x="22" y="68" width="56" height="15" rx="3" fill="#1B4D34"/>
    <text x="50" y="79" fill="#FFFFFF" font-family="'Nunito Sans', sans-serif" font-weight="900" font-size="10" text-anchor="middle" letter-spacing="1">HACCP</text>
  </svg>
)}

{type === 'bpom' && (
  <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="BPOM Logo">
    <!-- Background card circle -->
    <circle cx="50" cy="50" r="46" fill="#F4F9F5" stroke="#006037" stroke-width="3"/>

    <!-- Outer capsule outline typical for BPOM -->
    <rect x="18" y="24" width="64" height="52" rx="26" fill="white" stroke="#006037" stroke-width="2.5"/>

    <!-- Characteristic BPOM Dual Curves / Leaves -->
    <path d="M32 40 C32 30 46 28 50 36 C54 28 68 30 68 40 C68 56 50 68 50 68 C50 68 32 56 32 40 Z" fill="#006037"/>
    <path d="M38 42 C38 34 47 33 50 39 C53 33 62 34 62 42 C62 53 50 62 50 62 C50 62 38 53 38 42 Z" fill="#028A50"/>
    <circle cx="50" cy="45" r="4" fill="#FFFFFF"/>

    <!-- BPOM Text -->
    <text x="50" y="70" fill="#004D2C" font-family="'Nunito Sans', sans-serif" font-weight="900" font-size="10" text-anchor="middle" letter-spacing="1">BADAN POM</text>
  </svg>
)}

